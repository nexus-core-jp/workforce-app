// Prisma schema for workforce-app

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth.js (next-auth) tables ---
model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  name         String?
  role         UserRole  @default(EMPLOYEE)
  passwordHash String?
  active       Boolean   @default(true)

  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  departmentId String?
  department   Department? @relation("DepartmentUsers", fields: [departmentId], references: [id])

  accounts     Account[]
  sessions     Session[]

  timeEntries  TimeEntry[]
  dailyReports DailyReport[]
  leaveRequests LeaveRequest[]
  attendanceCorrections AttendanceCorrection[]
  shiftAssignments ShiftAssignment[]
  leaveLedgerEntries LeaveLedgerEntry[]

  payrollConfigs PayrollConfig[]
  monthlyPayrolls MonthlyPayroll[]

  departmentsApproving Department[] @relation("DepartmentApprover")
  attendanceCorrectionsApproved AttendanceCorrection[] @relation("AttendanceCorrectionApprover")
  leaveRequestsApproved LeaveRequest[] @relation("LeaveRequestApprover")
  closesClosedBy Close[] @relation("CloseClosedBy")
  auditLogsAsActor AuditLog[] @relation("AuditLogActor")
  passwordResetTokens PasswordResetToken[]
  faceDescriptors FaceDescriptor[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId, role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Multi-tenant core ---
model Tenant {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  plan                  TenantPlan @default(TRIAL)
  trialEndsAt           DateTime?
  stripeCustomerId      String?    @unique
  stripeSubscriptionId  String?
  faceAuthEnabled       Boolean    @default(false)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  users      User[]
  departments Department[]
  shiftPatterns ShiftPattern[]
  shiftAssignments ShiftAssignment[]
  timeEntries TimeEntry[]
  dailyReports DailyReport[]
  leaveRequests LeaveRequest[]
  leaveLedger LeaveLedgerEntry[]
  closes Close[]
  auditLogs AuditLog[]
  attendanceCorrections AttendanceCorrection[]
  passwordResetTokens PasswordResetToken[]
  payrollConfigs PayrollConfig[]
  monthlyPayrolls MonthlyPayroll[]
  tenantHolidays TenantHoliday[]
  faceDescriptors FaceDescriptor[]

  @@index([name])
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  approverUserId String?

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  approver  User?    @relation("DepartmentApprover", fields: [approverUserId], references: [id])
  users     User[]   @relation("DepartmentUsers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ShiftPattern {
  id                 String   @id @default(cuid())
  tenantId           String
  name               String
  plannedStart       String   // "HH:MM" local
  plannedEnd         String   // "HH:MM" local
  defaultBreakMinutes Int     @default(60)

  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments        ShiftAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ShiftAssignment {
  id             String   @id @default(cuid())
  tenantId       String
  userId         String
  shiftPatternId String
  startDate      DateTime // date-only semantics (store midnight JST)
  endDate        DateTime // inclusive

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shiftPattern   ShiftPattern @relation(fields: [shiftPatternId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, userId])
  @@index([tenantId, shiftPatternId])
}

model TimeEntry {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  date          DateTime // date-only semantics

  clockInAt     DateTime?
  clockOutAt    DateTime?
  breakStartAt  DateTime?
  breakEndAt    DateTime?

  workMinutes   Int      @default(0)
  status        TimeEntryStatus @default(OPEN)

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, userId, date])
  @@index([tenantId, date])
}

model AttendanceCorrection {
  id             String   @id @default(cuid())
  tenantId       String
  userId         String
  date           DateTime

  requestedClockInAt    DateTime?
  requestedClockOutAt   DateTime?
  requestedBreakStartAt DateTime?
  requestedBreakEndAt   DateTime?

  reason         String
  status         ApprovalStatus @default(PENDING)

  approverUserId String?
  decidedAt      DateTime?

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  approver       User?    @relation("AttendanceCorrectionApprover", fields: [approverUserId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, userId, date])
}

model DailyReport {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String
  date            DateTime

  route           String?
  cases           Int?
  workHoursText   String?

  incidentsText   String?
  notesText       String?
  announcementsText String?

  status          ReportStatus @default(DRAFT)
  submittedAt     DateTime?

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, userId, date])
  @@index([tenantId, date])
}

model LeaveRequest {
  id             String   @id @default(cuid())
  tenantId       String
  userId         String

  type           LeaveType
  halfType       HalfDayType?  // AM or PM (only when type=HALF)
  hours          Float?        // hours taken (only when type=HOURLY)
  startAt        DateTime
  endAt          DateTime
  reason         String?

  status         LeaveRequestStatus @default(PENDING)

  approverUserId String?
  decidedAt      DateTime?

  // When a paid-leave request is approved, we record ledger entries.
  ledgerEntries  LeaveLedgerEntry[]

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  approver       User?    @relation("LeaveRequestApprover", fields: [approverUserId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, userId])
}

model LeaveLedgerEntry {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  requestId     String?

  kind          LeaveLedgerKind
  days          Decimal  @db.Decimal(10, 2)
  note          String?

  effectiveDate DateTime // date-only semantics

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  request       LeaveRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())

  @@index([tenantId, userId, effectiveDate])
}

model Close {
  id          String   @id @default(cuid())
  tenantId    String
  month       String   // "YYYY-MM"
  scope       CloseScope @default(COMPANY)
  // Use empty string for COMPANY scope.
  departmentId String   @default("")

  closedByUserId String
  closedAt    DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  closedBy    User     @relation("CloseClosedBy", fields: [closedByUserId], references: [id])

  @@unique([tenantId, month, scope, departmentId])
  @@index([tenantId, month])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorUserId String?

  action      String
  entityType  String
  entityId    String

  beforeJson  Json?
  afterJson   Json?

  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor       User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
}

// --- Payroll ---
model PayrollConfig {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String

  payType      PayType  @default(MONTHLY)
  baseSalary   Int      @default(0)        // 月給 (円) or 基本日給
  hourlyRate   Int      @default(0)        // 時給 (円)
  commuteAllowance    Int @default(0)      // 通勤手当 (円/月)
  housingAllowance    Int @default(0)      // 住宅手当 (円/月)
  familyAllowance     Int @default(0)      // 家族手当 (円/月)
  otherAllowance      Int @default(0)      // その他手当 (円/月)
  otherAllowanceLabel String?              // その他手当の名称

  scheduledWorkDays    Int @default(20)    // 所定労働日数/月
  scheduledWorkMinutes Int @default(480)   // 所定労働時間/日 (分, default 8h)

  overtimeRate         Decimal @default(1.25) @db.Decimal(4, 2)  // 残業割増率
  lateNightRate        Decimal @default(1.50) @db.Decimal(4, 2)  // 深夜割増率
  holidayRate          Decimal @default(1.35) @db.Decimal(4, 2)  // 休日割増率

  bankName        String?   // 振込先銀行名
  bankCode        String?   // 銀行コード (4桁)
  branchName      String?   // 支店名
  branchCode      String?   // 支店コード (3桁)
  accountType     String?   // 普通/当座
  accountNumber   String?   // 口座番号 (7桁)
  accountHolder   String?   // 口座名義 (カナ)

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, userId])
  @@index([tenantId])
}

model MonthlyPayroll {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String
  month        String   // "YYYY-MM"

  // 労働時間内訳 (分)
  totalWorkMinutes     Int @default(0)
  scheduledMinutes     Int @default(0)   // 所定内労働時間
  overtimeMinutes      Int @default(0)   // 時間外 (法定超)
  lateNightMinutes     Int @default(0)   // 深夜 (22:00-05:00)
  holidayMinutes       Int @default(0)   // 休日労働
  workDays             Int @default(0)   // 出勤日数
  absentDays           Int @default(0)   // 欠勤日数

  // 給与計算結果 (円)
  basePay              Int @default(0)   // 基本給
  overtimePay          Int @default(0)   // 時間外手当
  lateNightPay         Int @default(0)   // 深夜手当
  holidayPay           Int @default(0)   // 休日手当
  commuteAllowance     Int @default(0)   // 通勤手当
  otherAllowances      Int @default(0)   // その他手当合計
  grossPay             Int @default(0)   // 総支給額

  // 控除 (将来拡張: 社保・税)
  deductions           Int @default(0)   // 控除合計
  netPay               Int @default(0)   // 差引支給額

  status       PayrollStatus @default(DRAFT)
  confirmedAt  DateTime?

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, userId, month])
  @@index([tenantId, month])
}

// --- Face authentication (顔認証) ---
model FaceDescriptor {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  descriptor String   @db.Text // JSON array of 128 floats (face-api.js descriptor)
  label      String?  // optional label like "正面", "左向き"

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, userId])
}

// --- Company custom holidays (会社休業日) ---
model TenantHoliday {
  id        String   @id @default(cuid())
  tenantId  String
  date      DateTime // date-only semantics (JST midnight)
  name      String   // e.g. "年末休業", "創立記念日"
  recurring Boolean  @default(false) // true = 毎年繰り返し (月日で判定)

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([tenantId, date])
  @@index([tenantId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum UserRole {
  EMPLOYEE
  APPROVER
  ADMIN
  SUPER_ADMIN
}

enum TimeEntryStatus {
  OPEN
  LOCKED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportStatus {
  DRAFT
  SUBMITTED
}

enum LeaveType {
  PAID       // 全日有給
  HALF       // 半日有給 (午前 or 午後)
  HOURLY     // 時間単位有給
  ABSENCE    // 欠勤
}

enum HalfDayType {
  AM  // 午前休
  PM  // 午後休
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_ATTENTION
}

enum LeaveLedgerKind {
  GRANT
  ADJUST
  USE
}

enum CloseScope {
  COMPANY
  DEPARTMENT
}

enum TenantPlan {
  TRIAL
  ACTIVE
  SUSPENDED
}

enum PayType {
  MONTHLY   // 月給制
  HOURLY    // 時給制
  DAILY     // 日給制
}

enum PayrollStatus {
  DRAFT      // 計算済み・未確定
  CONFIRMED  // 管理者確定
}
