# Copy to .env and fill in values
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/workforce_app?schema=public"

# Auth.js (next-auth)
AUTH_SECRET="replace-with-32+chars-random"
# For local dev
AUTH_URL="http://localhost:3002"

# Email notifications (optional — skipped if not set)
RESEND_API_KEY=""
NOTIFICATION_EMAIL=""

# LINE Login (optional — LINE login/registration disabled if not set)
# Get these from LINE Developers Console: https://developers.line.biz/
LINE_CHANNEL_ID=""
LINE_CHANNEL_SECRET=""

# Stripe (optional — billing features disabled if not set)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""
