# Copy to .env and fill in values

# --- Database (Neon PostgreSQL) ---
# Get your connection string from: https://console.neon.tech
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Auth.js (next-auth) ---
# Generate with: npx auth secret
AUTH_SECRET="replace-with-32+chars-random"

# For local dev
AUTH_URL="http://localhost:3002"

# Email notifications (optional — skipped if not set)
RESEND_API_KEY=""
NOTIFICATION_EMAIL=""

# Stripe (optional — billing features disabled if not set)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""

# LINE Login (optional — enables LINE OAuth login)
# LINE_CLIENT_ID=""
# LINE_CLIENT_SECRET=""

# LINE Bot (optional — enables LINE Bot punch commands)
# LINE_CHANNEL_SECRET=""
# LINE_CHANNEL_ACCESS_TOKEN=""

# LINE Notify (optional — sends notifications to LINE)
# LINE_NOTIFY_TOKEN=""
